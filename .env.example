OPENAI_API_KEY=your_generation_api_key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3-14B

GENERATION_API_KEY=
GENERATION_BASE_URL=
GENERATION_MODEL=
OPENAI_TIMEOUT=60
GENERATION_ENABLE_THINKING=false

EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSIONS=1024

RERANK_API_KEY=your_rerank_api_key
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=Qwen/Qwen3-Reranker-4B

RETRIEVAL_TOP_K=12
RERANK_TOP_N=5
CHUNK_TARGET_CHARS=550
CHUNK_OVERLAP_PAGES=1
MIN_CHUNK_CHARS=120

KNOWLEDGE_BASE_DIR=E:\RAG_projects\knowledge_base\tsinghua_stats
CHROMA_DB_DIR=E:\RAG_projects\rag_store\stats_chroma
RAG_MANIFEST_PATH=E:\RAG_projects\rag_store\stats_manifest.json

EMBEDDING_QUERY_INSTRUCTION=Retrieve passages from a statistics course knowledge base that best answer the user's question.
RERANK_INSTRUCTION=Please rerank the documents based on how well they answer the query about statistics concepts, methods, assumptions, and interpretation.
